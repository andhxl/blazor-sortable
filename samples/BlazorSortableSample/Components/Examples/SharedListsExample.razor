<ExampleSection Id="@Id"
                Title="Shared lists"
                CodeContent="@codeContent">
    <RadzenStack Orientation="Orientation.Horizontal">
        <Sortable TItem="ClassA"
                  Items="Utils.CreateItemList<ClassA>(5)"
                  Class="items-column"
                  Group="group1">
            <RadzenCard class="item">
                @context
            </RadzenCard>
        </Sortable>

        <Sortable TItem="ClassA"
                  Items="Utils.CreateItemList<ClassA>(5, 6)"
                  Class="items-column"
                  Group="group1">
            <RadzenCard class="item">
                @context
            </RadzenCard>
        </Sortable>
    </RadzenStack>
</ExampleSection>

@code {
    [Parameter, EditorRequired]
    public string Id { get; set; }

    private string codeContent = @"
<div class=""row"">
    <Sortable TItem=""ClassA""
              Items=""Utils.CreateItemList<ClassA>(5)""
              Class=""items-column""
              Group=""group1"">
        <div class=""item"">
            @context
        </div>
    </Sortable>

    <Sortable TItem=""ClassA""
              Items=""Utils.CreateItemList<ClassA>(5, 6)""
              Class=""items-column""
              Group=""group1"">
        <div class=""item"">
            @context
        </div>
    </Sortable>
</div>";
}
