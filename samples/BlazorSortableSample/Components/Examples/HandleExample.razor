<ExampleSection Id="@Id"
                Title="Handle"
                CodeContent="@codeContent">
    <Sortable TItem="ClassA"
              Items="Utils.CreateItemList<ClassA>(5)"
              Class="items-column"
              Handle=".handle"
              ForceFallback="false">
        <RadzenCard class="item">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <div class="handle" />
                @context
            </RadzenStack>
        </RadzenCard>
    </Sortable>
</ExampleSection>

@code {
    [Parameter, EditorRequired]
    public string Id { get; set; }

    private string codeContent = @"
<Sortable TItem=""ClassA""
          Items=""Utils.CreateItemList<ClassA>(5)""
          Class=""items-column""
          Handle="".handle""
          ForceFallback=""false"">
    <div class=""item item-with-handle"">
        <div class=""handle"" />
        @context
    </div>
</Sortable>";
}
